#include "mbed.h"

#define BLINKING_RATE 250ms

int main()
{
    DigitalOut led1(LED1); // Green
    DigitalOut led2(LED2); // Blue
    DigitalOut led3(LED3); // Red

    int counter = 0;

    while (true) {
        led2 = !led2;

        if (counter % 2 == 0) {
            led1 = !led1;
        }

        if (counter % 4 == 0) {
            led3 = !led3;
        }

        ThisThread::sleep_for(BLINKING_RATE);
        counter++;

        if (counter >= 8) {
            counter = 0;
        }
    }
}
