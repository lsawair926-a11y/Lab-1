#include "mbed.h"

#define BLINKING_RATE 500ms

int main()
{
    DigitalOut led1(LED1); // Green
    DigitalOut led2(LED2); // Blue
    DigitalOut led3(LED3); // Red

    while (true) {
        // Blink All
        led1 = 1; led2 = 1; led3 = 1;
        ThisThread::sleep_for(BLINKING_RATE);

        // All Off
        led1 = 0; led2 = 0; led3 = 0;
        ThisThread::sleep_for(BLINKING_RATE);
    }
}
