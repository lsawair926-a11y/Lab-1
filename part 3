#include "mbed.h"

#define BLINKING_RATE 200ms

DigitalOut led1(LED1); // Green
DigitalOut led2(LED2); // Blue
DigitalOut led3(LED3); // Red

void ping_pong(){
    led1=1;
    ThisThread::sleep_for(BLINKING_RATE);
    led1=0;
    ThisThread::sleep_for(BLINKING_RATE);

    led2=1;
    ThisThread::sleep_for(BLINKING_RATE);
    led2=0;
    ThisThread::sleep_for(BLINKING_RATE);

    led3=1;
    ThisThread::sleep_for(BLINKING_RATE);
    led3=0;
    ThisThread::sleep_for(BLINKING_RATE);

    led2=1;
    ThisThread::sleep_for(BLINKING_RATE);
    led2=0;
    ThisThread::sleep_for(BLINKING_RATE);
}

int main(){

    while (true) {

        ping_pong();

    }
}
